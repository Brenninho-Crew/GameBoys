{
  "name": "gameboys",
  "version": "1.0.0",
  "description": "GameBoys - C++ Game Boy Emulator (Windows, Android, Web)",
  "author": "Brenninho Crew",
  "license": "Apache-2.0",
  "scripts": {
    "build:windows": "cmake -S . -B build/windows -G \"MinGW Makefiles\" && cmake --build build/windows",
    "build:android": "cmake -S . -B build/android -DCMAKE_TOOLCHAIN_FILE=%ANDROID_NDK%/build/cmake/android.toolchain.cmake -DANDROID_ABI=arm64-v8a -DANDROID_PLATFORM=android-24 && cmake --build build/android",
    "build:web": "emcc main.cpp -o web/gameboys.js -s USE_SDL=2 -s WASM=1 -s EXPORTED_FUNCTIONS=\"['_loadROM','_start','_pressButton','_releaseButton','_malloc']\" -s EXPORTED_RUNTIME_METHODS=\"['ccall','cwrap']\"",
    "clean": "rm -rf build"
  },
  "devDependencies": {},
  "keywords": [
    "gameboy",
    "emulator",
    "c++",
    "sdl2",
    "android",
    "windows",
    "webassembly"
  ]
}